# AAIA LLM Provider Configuration
# Copy this file to .env and configure your desired providers
# Never commit .env to version control!

# ============================================
# Default Provider Configuration
# ============================================

# Choose your default provider: ollama, openai, github, azure, venice
LLM_DEFAULT_PROVIDER=ollama

# Optional: Fallback provider if primary fails or unavailable
LLM_FALLBACK_PROVIDER=

# ============================================
# Phase 2.5: Economic Model Selection
# ============================================
# AAIA now automatically selects the CHEAPEST suitable model based on:
#   - Task type: code, reasoning, vision, general
#   - Complexity: low (4K context), medium (8K), high (32K+)
#   - Cost: Picks cheapest model that meets requirements
#
# Example: For a simple task, it might pick:
#   Venice: llama-3.2-3b (0.0002 DIEM) instead of llama-3.3-70b (0.0006 DIEM)
#   OpenAI: gpt-3.5-turbo instead of gpt-4o
#
# Model selection happens IN CODE, not in .env:
#   router.call_model(prompt, task_type="code", complexity="low", max_cost=0.5)
#
# The MODEL settings below are FALLBACKS when:
#   - No suitable model found for requirements
#   - Model discovery fails
#   - You explicitly override with model="specific-model-id"
#
# Cost Savings: ~27% reduction on typical workloads
# ============================================

# ============================================
# Ollama (Local Models) - FREE
# ============================================
# Best for: Privacy, no API costs, offline usage
# Requires: Ollama installed locally (https://ollama.ai)

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3

# ============================================
# OpenAI - PAID
# ============================================
# Best for: Highest quality models, production use
# Requires: OpenAI account and API key (https://platform.openai.com/api-keys)

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION=
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=3
OPENAI_MAX_TOKENS=4096

# ============================================
# GitHub Models - FREE (Preview)
# ============================================
# Best for: Free cloud AI during preview period
# Requires: GitHub account with Models API access (waitlist)
# API Key: GitHub Personal Access Token with 'model' scope

GITHUB_ENABLED=false
GITHUB_API_KEY=
GITHUB_MODEL=gpt-4o
GITHUB_TIMEOUT=120
GITHUB_MAX_RETRIES=3

# ============================================
# Azure OpenAI - PAID (Enterprise)
# ============================================
# Best for: Enterprise deployments, Microsoft ecosystem, SLAs
# Requires: Azure subscription, Azure OpenAI Service access

AZURE_ENABLED=false
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_NAME=
AZURE_API_VERSION=2024-02-01
AZURE_TIMEOUT=120
AZURE_MAX_RETRIES=3

# ============================================
# Venice AI - Token-Based (VVV Staking Required)
# ============================================
# Best for: Privacy-focused, token-staking model
# Requires: Venice.ai account + VVV token staking
# Cost Model: Stake VVV tokens → Earn daily DIEM allocation
# Pricing: 1 DIEM ≈ $631 USD (as of 2024)
# Example: ~$2000 VVV staked → 0.49 DIEM/day allocation
# 
# Learn more:
# - https://venice.ai/blog/understanding-venice-compute-units-vcu
# - https://venice.ai/lp/diem
#
# Features: Model discovery, compatibility mapping, DIEM tracking

VENICE_ENABLED=false
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

# Venice budget management
VENICE_CHECK_DIEM=true           # Check DIEM before each request
VENICE_DIEM_WARNING=1.0          # Warn when DIEM < this value
VENICE_DIEM_CRITICAL=0.1         # Error when DIEM < this value  
VENICE_AUTO_FALLBACK=true        # Auto-fallback to other provider when low

# ============================================
# Other OpenAI-Compatible APIs
# ============================================
# For: LM Studio, LocalAI, OpenRouter, Together AI, Groq, etc.
# Set OPENAI_ENABLED=true and override OPENAI_BASE_URL

# Example for LM Studio (local):
# OPENAI_ENABLED=true
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=local-model

# Example for OpenRouter (access multiple models):
# OPENAI_ENABLED=true
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-your-key-here
# OPENAI_MODEL=anthropic/claude-3.5-sonnet

# Example for Groq (fast inference):
# OPENAI_ENABLED=true
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your-key-here
# OPENAI_MODEL=llama-3.3-70b-versatile

# ============================================
# Recommended Configurations
# ============================================

# Configuration 1: Local-First (Lowest Cost)
# LLM_DEFAULT_PROVIDER=ollama
# LLM_FALLBACK_PROVIDER=
# OLLAMA_ENABLED=true
# Result: 100% local, no API costs, full privacy

# Configuration 2: GitHub Models (During Preview)
# LLM_DEFAULT_PROVIDER=github
# LLM_FALLBACK_PROVIDER=ollama
# GITHUB_ENABLED=true
# OLLAMA_ENABLED=true
# Result: Free GitHub preview → Local fallback

# Configuration 3: Production Quality (OpenAI)
# LLM_DEFAULT_PROVIDER=openai
# LLM_FALLBACK_PROVIDER=ollama
# OPENAI_ENABLED=true
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_ENABLED=true
# Result: OpenAI quality → Local when budget-conscious

# Configuration 4: Venice Token Staking
# LLM_DEFAULT_PROVIDER=venice
# LLM_FALLBACK_PROVIDER=ollama
# VENICE_ENABLED=true
# OLLAMA_ENABLED=true
# Result: Token-based DIEM credits → Local fallback
# Note: Requires VVV token staking (~$2000 for 0.49 DIEM/day)

# ============================================
# Other AAIA Settings
# ============================================

# Database
DB_PATH=data/scribe.db
DB_TIMEOUT=30
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=3600

# Scheduler
SCHEDULER_ENABLED=true
DIAGNOSIS_INTERVAL=3600
HEALTH_CHECK_INTERVAL=1800
REFLECTION_INTERVAL=86400
EVOLUTION_CHECK_INTERVAL=7200

# Economics
INITIAL_BALANCE=100.0
LOW_BALANCE_THRESHOLD=10.0
INFERENCE_COST=0.01
TOOL_CREATION_COST=1.0
INCOME_GENERATION_ENABLED=true

# Evolution
EVOLUTION_MAX_RETRIES=3
EVOLUTION_SAFETY_MODE=true
EVOLUTION_BACKUP_BEFORE_MODIFY=true
EVOLUTION_MAX_CODE_LINES=500
EVOLUTION_REQUIRE_TESTS=false

# Tools
TOOLS_DIR=tools
BACKUP_DIR=backups
TOOLS_AUTO_DISCOVER=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true

# ============================================
# Security Notes
# ============================================
# 1. Never commit this .env file to git
# 2. Keep API keys secure and rotate regularly
# 3. Use different keys for dev/staging/production
# 4. Set spending limits in provider dashboards
# 5. Monitor usage with 'aaia budget' command
# 6. Use least-privilege API keys (minimum required scopes)

# ============================================
# Phase 2.5: Using Economic Model Selection
# ============================================
# You don't configure model selection in .env - it happens in code!
#
# Example 1: Simple task (picks cheap model automatically)
#   router.call_model(
#       prompt="What is 2+2?",
#       task_type="general",
#       complexity="low"
#   )
#   Result: Selects cheapest model with 4K+ context
#
# Example 2: Code task (needs code-optimized model)
#   router.call_model(
#       prompt="Review this Python code...",
#       task_type="code",
#       complexity="medium"
#   )
#   Result: Selects cheapest code-capable model with 8K+ context
#
# Example 3: Complex reasoning (needs large context + reasoning)
#   router.call_model(
#       prompt="Analyze this research paper...",
#       task_type="reasoning",
#       complexity="high"
#   )
#   Result: Selects cheapest reasoning model with 32K+ context
#
# Example 4: Budget constraint (max cost)
#   router.call_model(
#       prompt="Quick summary...",
#       complexity="low",
#       max_cost=0.3  # Don't spend more than 0.3 per 1K tokens
#   )
#   Result: Only considers models costing ≤0.3 per 1K tokens
#
# Example 5: Force specific model (bypass auto-selection)
#   router.call_model(
#       prompt="Use this exact model...",
#       model="llama-3.3-70b"  # Explicit model override
#   )
#   Result: Uses specified model, ignores auto-selection
#
# See docs/PHASE_2.5_VERIFICATION.md for detailed cost analysis

