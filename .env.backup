# AAIA Test Configuration - 30 Minute Dry Run
# This configuration runs all autonomous tasks within a 30-minute window

# LLM Provider
LLM_DEFAULT_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=venice

# Venice AI Configuration
VENICE_ENABLED=true
VENICE_API_KEY=VENICE-INFERENCE-KEY-_vN1N3YFK0G9zFzO8lfciqrlPGfNhjKOQS9JG5RH6N
VENICE_MODEL=llama-3.3-70b

# Venice Budget Management
VENICE_CHECK_DIEM=true
VENICE_DIEM_WARNING=0.15
VENICE_DIEM_CRITICAL=0.1
VENICE_AUTO_FALLBACK=false

# Ollama (Local Server)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://192.168.178.104:11434
OLLAMA_MODEL=phi4-mini:latest
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3

# Database
DB_PATH=data/scribe_test.db

# Economics
INITIAL_BALANCE=100.0
LOW_BALANCE_THRESHOLD=10.0
INFERENCE_COST=0.01
TOOL_CREATION_COST=1.0

# Logging
LOG_LEVEL=INFO

# ============================================
# SCHEDULER - 30 MINUTE TEST WINDOW
# ============================================
# Adjusted intervals for testing:
# - Health check: every 5 minutes (6 runs in 30 min)
# - Diagnosis: every 10 minutes (3 runs in 30 min)
# - Reflection: every 15 minutes (2 runs in 30 min)
# - Evolution check: every 20 minutes (1-2 runs in 30 min)

SCHEDULER_ENABLED=true
DIAGNOSIS_INTERVAL=600
HEALTH_CHECK_INTERVAL=300
REFLECTION_INTERVAL=900
EVOLUTION_CHECK_INTERVAL=1200

# ============================================
# WEB SERVER - ENABLED FOR MONITORING
# ============================================
WEB_SERVER_ENABLED=true
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=5000
WEB_SERVER_DEBUG=false
WEB_SERVER_SECRET_KEY=test-dry-run-secret-key

# WebSocket Settings
WEB_SOCKETIO_ASYNC_MODE=threading
WEB_SOCKETIO_CORS_ALLOWED_ORIGINS=*
WEB_SOCKETIO_PING_TIMEOUT=60
WEB_SOCKETIO_PING_INTERVAL=25
